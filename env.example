# ─── MongoDB Atlas ────────────────────────────────────────────────────────
# Conseguís esta URL en: MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/impulsoweb?retryWrites=true&w=majority

# ─── URL del frontend ──────────────────────────────────────────────────────
# En desarrollo: http://localhost:5173
# En producción: https://tu-dominio.vercel.app
FRONTEND_URL=http://localhost:5173

# ─── Puerto del servidor ───────────────────────────────────────────────────
PORT=4000
